#!/bin/sh
# pre-commit hook for KnockWise
# 安装: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 跳过: PRE_COMMIT_SKIP=1 git commit ...

set -e

cd "$(git rev-parse --show-toplevel)"

if [ -n "$PRE_COMMIT_SKIP" ]; then
  echo "⏭️  PRE_COMMIT_SKIP=$PRE_COMMIT_SKIP, 跳过所有检查"
  exit 0
fi

echo "🔍 pre-commit 检查..."

staged_files=$(git diff --cached --name-only)
backend_changed=$(echo "$staged_files" | grep -E "^backend/" | grep -v "__pycache__" || true)
frontend_changed=$(echo "$staged_files" | grep -E "^frontend/" | grep -v "node_modules" || true)

# ─── 1. 后端 pytest(风险范围感知的 fail closed + 最小健康探针 · P0-2)───
if [ -n "$backend_changed" ]; then
  if [ ! -d "backend/.venv" ]; then
    echo "❌ backend/.venv 不存在,禁止 commit"
    echo "   恢复: cd backend && python3 -m venv .venv && .venv/bin/python -m pip install -r requirements.txt"
    echo "   绕过(仅紧急): PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  elif [ ! -x "backend/.venv/bin/python" ]; then
    echo "❌ backend/.venv/bin/python 不可执行,禁止 commit"
    echo "   恢复: rm -rf backend/.venv && cd backend && python3 -m venv .venv && .venv/bin/python -m pip install -r requirements.txt"
    echo "   绕过(仅紧急): PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  fi
  # 探针:pytest 是否可用(避免直接跑测试时才发现环境损坏)
  set +e
  pytest_probe=$(cd backend && ./.venv/bin/python -m pytest --version 2>&1)
  pytest_probe_rc=$?
  set -e
  if [ "$pytest_probe_rc" -ne 0 ]; then
    echo "❌ pytest 不可用,禁止 commit"
    echo "   stdout/stderr: $pytest_probe"
    echo "   恢复: cd backend && ./.venv/bin/python -m pip install -r requirements.txt"
    echo "   绕过(仅紧急): PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  fi
  echo "📦 backend 改动 → 跑 pytest..."
  # 捕获真实退出码：`... | tail` 的退出码取自末端 tail(恒 0),会吞掉 pytest 失败
  set +e
  pytest_out=$(cd backend && ./.venv/bin/python -m pytest tests/ --tb=short -q 2>&1)
  pytest_rc=$?
  set -e
  echo "$pytest_out" | tail -30
  if [ "$pytest_rc" -ne 0 ]; then
    echo ""
    echo "❌ pytest 失败,禁止 commit"
    echo "   绕过: PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  fi
  echo "✅ pytest 通过"
fi

# ─── 2. 前端 tsc(风险范围感知的 fail closed + 最小健康探针 · P0-2) ──
if [ -n "$frontend_changed" ]; then
  if [ ! -d "frontend/node_modules" ]; then
    echo "❌ frontend/node_modules 不存在,禁止 commit"
    echo "   恢复: cd frontend && npm ci"
    echo "   绕过(仅紧急): PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  elif [ ! -x "frontend/node_modules/.bin/tsc" ]; then
    echo "❌ frontend/node_modules/.bin/tsc 不可执行,禁止 commit"
    echo "   恢复: cd frontend && rm -rf node_modules && npm ci"
    echo "   绕过(仅紧急): PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  fi
  # 探针:tsc 是否可用
  set +e
  tsc_probe=$(cd frontend && ./node_modules/.bin/tsc --version 2>&1)
  tsc_probe_rc=$?
  set -e
  if [ "$tsc_probe_rc" -ne 0 ]; then
    echo "❌ tsc 不可用,禁止 commit"
    echo "   stdout/stderr: $tsc_probe"
    echo "   恢复: cd frontend && npm ci"
    echo "   绕过(仅紧急): PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  fi
  echo "🎨 frontend 改动 → 跑 tsc..."
  # 同 pytest：捕获真实退出码,避免 `| tail` 吞掉 tsc 失败
  set +e
  tsc_out=$(cd frontend && ./node_modules/.bin/tsc --noEmit 2>&1)
  tsc_rc=$?
  set -e
  echo "$tsc_out" | tail -30
  if [ "$tsc_rc" -ne 0 ]; then
    echo ""
    echo "❌ tsc 失败,禁止 commit"
    echo "   绕过: PRE_COMMIT_SKIP=1 git commit ..."
    exit 1
  fi
  echo "✅ tsc 通过"
fi

# ─── 3. 大 commit 警告(对治问题 #2 代码先行) ──────────────
diff_lines=$(git diff --cached --shortstat | awk '{print $1}' | tr -d ',' || echo "0")
if [ -n "$diff_lines" ] && [ "$diff_lines" -gt 500 ] 2>/dev/null; then
  echo ""
  echo "⚠️  警告: 本次 commit 变更 $diff_lines 行 (> 500)"
  echo "   是否违反'代码先行'原则?考虑拆成多个 commit"
  printf "   确认继续? [y/N] "
  read -r reply
  case "$reply" in
    [Yy]|[Yy][Ee][Ss]) echo "   → 继续" ;;
    *) echo "   → 中止,拆 commit 再来"; exit 1 ;;
  esac
fi

# ─── 4. 6 步 v2 DOD 校验(对治 DOD 缺失) ──────────────────────
task_files=$(echo "$staged_files" | grep -E "^docs/tasks/.*\.md$" || true)
if [ -n "$task_files" ]; then
  if [ ! -f "scripts/check-step.py" ]; then
    echo ""
    echo "⚠️  检测到 docs/tasks/ 改动,但 scripts/check-step.py 不存在"
    echo "   TODO: 接入 6 步 v2 DOD 校验"
    echo "   临时跳过,记得手动验证文档符合 docs/DOD.md"
  else
    echo ""
    echo "📋 docs/tasks/ 改动 → 跑 6 步 v2 DOD 校验..."
    failed=0
    for file in $task_files; do
      step=""
      case "$(basename "$file")" in
        research.md)     step="research" ;;
        spec.md)         step="spec" ;;
        plan.md)         step="plan" ;;
        tasks.md)        step="tasks" ;;
        test-cases.md)   step="implement" ;;
        verify.md)       step="verify" ;;
        retro.md)        step="retro" ;;
      esac
      if [ -z "$step" ]; then
        continue
      fi
      echo "   → $step: $file"
      # 捕获真实退出码：`... | tail` 的退出码取自末端 tail(恒 0),会吞掉 checker 失败
      set +e
      check_out=$(python3 scripts/check-step.py "$step" "$file" 2>&1)
      check_rc=$?
      set -e
      printf '%s\n' "$check_out" | tail -10
      if [ "$check_rc" -ne 0 ]; then
        failed=1
      fi
    done
    if [ $failed -ne 0 ]; then
      echo ""
      echo "❌ 6 步 v2 DOD 校验失败,禁止 commit"
      echo "   完整 DOD 定义见 docs/DOD.md"
      exit 1
    fi
  fi
fi

# ─── 4.5 task.yaml 契约校验(P0-7) ───────────────────────────
task_yaml_files=$(echo "$staged_files" | grep -E "^docs/tasks/.+/task\.yaml$" || true)
if [ -n "$task_yaml_files" ]; then
  if [ ! -f "scripts/check-task.py" ]; then
    echo ""
    echo "⚠️  检测到 task.yaml 改动,但 scripts/check-task.py 不存在"
    echo "   临时跳过 task 契约校验"
  else
    echo ""
    echo "📋 task.yaml 改动 → 跑任务目录契约校验..."
    for file in $task_yaml_files; do
      task_dir=$(dirname "$file")
      echo "   → $task_dir"
      # 捕获真实退出码：`... | tail` 的退出码取自末端 tail(恒 0),会吞掉 checker 失败
      set +e
      check_out=$(python3 scripts/check-task.py --dir "$task_dir" --view index 2>&1)
      check_rc=$?
      set -e
      printf '%s\n' "$check_out" | tail -15
      if [ "$check_rc" -ne 0 ]; then
        echo ""
        echo "❌ task.yaml 契约校验失败,禁止 commit"
        echo "   修复 task.yaml 或调 exempt 列表"
        exit 1
      fi
    done
  fi
fi

# ─── 5. tasks.md 同步校验(对治问题 #N 任务追踪不更新) ─────
# 规则(CLAUDE.md § 6.5):实施类 commit (backend/ frontend/ scripts/) 必须同步对应 task 的 tasks.md
# 例外:纯文档 commit (docs/ memory/ CLAUDE.md) → 不要求
# 跳过: SKIP_TASKS_SYNC=1 git commit ...
if [ -n "$backend_changed$frontend_changed" ] && [ -z "$SKIP_TASKS_SYNC" ]; then
  tasks_changed=$(echo "$staged_files" | grep -E "^docs/tasks/.+/tasks\.md$" || true)
  if [ -z "$tasks_changed" ]; then
    echo ""
    echo "❌ tasks.md 同步校验失败:"
    echo "   检测到实施类文件改动,但没有 tasks.md 同步"
    echo ""
    echo "   改动文件(前 5 条):"
    echo "$backend_changed$frontend_changed" | grep -E "^(backend|frontend)/" | head -5 | sed 's/^/     /'
    echo ""
    echo "   按 CLAUDE.md § 6.5 (及 feedback-immediate-tasks-md-sync memory),必须:"
    echo "     1. 把对应 task 标 - [x] ✅ DONE — commit \`hash\`"
    echo "     2. 加实际耗时 vs 估时"
    echo "     3. 更新 § 6 总估时 + § 7 实施顺序"
    echo ""
    echo "   跳过方式(仅用于纯 bug fix / 纯 docs 改动):"
    echo "     SKIP_TASKS_SYNC=1 git commit -m '...'"
    echo "     (PRE_COMMIT_SKIP=1 也可跳过全部检查)"
    exit 1
  fi
  echo "✅ tasks.md 同步校验通过"
fi

echo ""
echo "✅ pre-commit 全部通过"
